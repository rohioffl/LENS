  sub_platform_public_3 -> igw_default;
  sub_platform_private_3 -> router_router_platform_vpc_asia_south1_1;
  sub_platform_public_2 -> igw_default;
  nat_cloud_nat_platform_vpc_asia_south1_1 -> igw_default [style=dashed, label="outbound"];
}
