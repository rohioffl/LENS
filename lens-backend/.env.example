# Copy this file to `.env` and customize values for your environment.

# Default behavior for ecs2gke manifest generation
ECS_MANIFEST_AWS_CREDENTIAL_MODE=yes
ECS_MANIFEST_GEMINI_MODEL=gemini-1.5-flash
ECS_MANIFEST_GEMINI_FALLBACKS=gemini-1.5-pro,gemini-1.0-pro

# Provide your real Gemini API key here. This will be exported as GEMINI_API_KEY.
ECS_MANIFEST_GEMINI_API_KEY_OVERRIDE=your-gemini-api-key
GEMINI_API_KEY=${ECS_MANIFEST_GEMINI_API_KEY_OVERRIDE}
